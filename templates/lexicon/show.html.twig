{% extends 'base.html.twig' %}

{% block title %}Lexicon{% endblock %}

{% block body %}
    <h1>Lexicon</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ lexicon.id }}</td>
            </tr>
            <tr>
                <th>Term</th>
                <td>{{ lexicon.term }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ lexicon.slug }}</td>
            </tr>
            <tr>
                <th>Definition</th>
                <td>{{ lexicon.definition }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_lexicon_index') }}">back to list</a>

    <a href="{{ path('app_lexicon_edit', {'id': lexicon.id}) }}">edit</a>

    {{ include('lexicon/_delete_form.html.twig') }}
{% endblock %}

<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        {# LA LIGNE CRUCIALE POUR LE TÉLÉPHONE EST ICI #}
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        
        <title>{% block title %}L'Empreinte | Sandrine Tribhou - Shiatsu Traditionnel{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🌿</text></svg>">
        
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    {# On utilise vos nouvelles couleurs zen-sand et zen-ink #}
    <body class="bg-zen-sand text-zen-ink font-sans antialiased">
        
        {# Navigation épurée et responsive #}
        <nav class="py-6 md:py-10 px-6 md:px-16 flex justify-between items-center bg-white/30 backdrop-blur-md sticky top-0 z-50 border-b border-zen-clay/30">
            <a href="{{ path('app_home') }}" class="text-lg md:text-xl tracking-[0.3em] font-serif italic text-zen-ink">L'Empreinte</a>
            
            {# Liens (masqués sur très petits mobiles pour l'instant pour la clarté) #}
            <div class="hidden md:flex space-x-10 text-[10px] uppercase tracking-[0.2em] font-semibold text-zen-ink/60">
                <a href="{{ path('app_service') }}" class="hover:text-zen-bronze transition-colors">Soins</a>
                <a href="#" class="hover:text-zen-bronze transition-colors">Philosophie</a>
                <a href="#" class="hover:text-zen-bronze transition-colors">Contact</a>
            </div>

            <a href="#" class="bg-zen-ink text-zen-sand px-6 py-3 rounded-full text-[10px] uppercase tracking-widest font-bold hover:bg-zen-bronze transition-all shadow-sm">
                Réserver
            </a>
        </nav>

        <main>
            {% block body %}{% endblock %}
        </main>

        <footer class="py-20 text-center text-zen-ink/30 text-[10px] uppercase tracking-[0.4em]">
            &copy; {{ "now"|date("Y") }} L'Empreinte — Sandrine Tribhou — Toulouse & Tournefeuille
        </footer>
    </body>
</html>
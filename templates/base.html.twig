<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}L'Empreinte - Shiatsu & MTC{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2290%22>🏮</text></svg>">
        
        {{ importmap('app') }}

        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}
    </head>

    <body class="bg-zen-sand text-zen-ink antialiased">
        <header class="fixed top-0 w-full z-[100] bg-zen-sand/80 backdrop-blur-md border-b border-zen-ink/5">
            <nav class="max-w-[1440px] mx-auto px-[150px] h-20 flex items-center justify-between font-eb-garamond">
                {# 1. LOGO #}
                <a href="{{ path('app_home') }}" class="text-xl font-cormorant italic tracking-widest uppercase text-zen-ink">
                    L'Empreinte
                </a>

                {# 2. BLOC CENTRAL DE NAVIGATION #}
                <div class="flex gap-8 text-[10px] uppercase tracking-[0.25em] font-medium text-zen-ink/70 items-center">
                    <a href="{{ path('app_soins_public') }}" class="hover:text-zen-forest transition-colors">Soins</a>
                    <a href="{{ path('app_sanctuary_article') }}" class="hover:text-zen-forest transition-colors">Sanctuaire</a>
                    <a href="{{ path('app_lexique_public') }}" class="hover:text-zen-forest transition-colors">Lexique</a>
                    <a href="{{ path('app_exchange_init') }}" class="hover:text-zen-forest transition-colors">Contact</a>

                    {# SÉPARATEUR #}
                    <div class="h-4 w-[1px] bg-zen-ink/10 mx-2"></div>
                    
                    {# LOGIQUE UTILISATEUR #}
                    {% if app.user %}
                        {# SI ADMIN (Sandrine) #}
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_admin_dashboard') }}" class="text-zen-forest font-bold tracking-[0.1em] mr-4 flex items-center gap-2">
                                <span class="w-1.5 h-1.5 bg-zen-forest rounded-full"></span>
                                Administration
                            </a>
                        {% endif %}

                        {# NOM ET DÉCONNEXION #}
                        <span class="text-zen-forest italic lowercase font-normal mr-3">{{ app.user.firstName }}</span>
                        <a href="{{ path('app_logout') }}" class="hover:text-red-800 transition-colors">Déconnexion</a>
                    {% else %}
                        {# SI ANONYME #}
                        <a href="{{ path('app_login') }}" class="hover:text-zen-forest transition-colors">Connexion</a>
                    {% endif %}
                </div>

                {# 3. BOUTON RÉSERVER #}
                <a href="{{ path('app_appointment_new') }}" class="border border-zen-ink text-zen-ink px-8 py-2.5 text-[11px] font-bold uppercase tracking-[0.2em] rounded-full hover:bg-zen-ink hover:text-zen-sand transition-all shadow-sm">
                    Réserver
                </a>
            </nav>
        </header>

        <div class="pt-20">
            {# ZONE DES MESSAGES FLASH #}
            <div class="max-w-[1440px] mx-auto px-[150px] mt-8">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                    <div class="flash-message p-4 mb-4 font-eb-garamond italic text-sm border rounded-sm transition-opacity duration-1000
                        {{ label == 'success' ? 'bg-zen-forest/10 text-zen-forest border-zen-forest/20' : 'bg-zen-ink/5 text-zen-ink border-zen-ink/10' }}">
                        {{ message }}
                        <button onclick="this.parentElement.remove()" class="float-right opacity-30 hover:opacity-100">✕</button>
                    </div>
                    {% endfor %}
                {% endfor %}
            </div>

            {% block body %}{% endblock %}
        </div>

        <script>
            document.querySelectorAll('.flash-message').forEach(flash => {
                setTimeout(() => {
                    flash.style.opacity = '0';
                    setTimeout(() => flash.remove(), 1000);
                }, 5000);
            });
        </script>
    </body>
</html>
{% extends 'base.html.twig' %}

{% block title %}Initier un échange | L'EMPREINTE{% endblock %}

{% block body %}
<main class="max-w-[1440px] mx-auto px-[150px] pt-32 pb-32 min-h-screen">
    
    <div class="flex flex-col md:flex-row gap-24">
        
        {# Bloc Gauche : L'intention #}
        <div class="md:w-1/3">
            <h1 class="text-5xl font-cormorant italic text-zen-ink leading-tight mb-16">
                Initier la <br> Synchronicité
            </h1>
            
            <div class="border-l border-zen-forest/20 pl-10">
                <p class="font-eb-garamond text-lg text-zen-ink/70 leading-relaxed italic">
                    Le soin commence dès les premiers mots. Partagez votre recherche d'équilibre, Sandrine vous lira avec attention.
                </p>
            </div>
        </div>

        {# Bloc Droit : Le Formulaire complet #}
        <div class="md:w-2/3 mt-12 bg-white/40 backdrop-blur-md p-16 rounded-sm border border-zen-ink/5 shadow-sm">
            
            {% for message in app.flashes('success') %}
                <div class="mb-8 p-4 bg-zen-forest/10 border border-zen-forest/20 text-zen-forest font-eb-garamond italic">
                    {{ message }}
                </div>
            {% endfor %}

            {{ form_start(form, {'attr': {'class': 'space-y-10'}}) }}
                
                {# SECTION 1 : IDENTITÉ #}
                <div class="grid grid-cols-2 gap-8">
                    <div class="space-y-2">
                        {{ form_label(form.firstName, null, {'label_attr': {'class': 'block text-[10px] uppercase tracking-[0.3em] text-zen-ink/40 font-medium'}}) }}
                        {{ form_widget(form.firstName, {'attr': {'class': 'w-full bg-transparent border-b border-zen-ink/10 py-3 font-eb-garamond text-lg outline-none focus:border-zen-forest transition-all'}}) }}
                    </div>
                    <div class="space-y-2">
                        {{ form_label(form.lastName, null, {'label_attr': {'class': 'block text-[10px] uppercase tracking-[0.3em] text-zen-ink/40 font-medium'}}) }}
                        {{ form_widget(form.lastName, {'attr': {'class': 'w-full bg-transparent border-b border-zen-ink/10 py-3 font-eb-garamond text-lg outline-none focus:border-zen-forest transition-all'}}) }}
                    </div>
                </div>

                <div class="space-y-2">
                    {{ form_label(form.email, null, {'label_attr': {'class': 'block text-[10px] uppercase tracking-[0.3em] text-zen-ink/40 font-medium'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': 'w-full bg-transparent border-b border-zen-ink/10 py-3 font-eb-garamond text-lg outline-none focus:border-zen-forest transition-all'}}) }}
                </div>

                {# BLOC MOT DE PASSE (Unique et avec Stimulus) #}
                <div class="space-y-2 relative" data-controller="password-visibility">
                    {{ form_label(form.plainPassword, null, {'label_attr': {'class': 'block text-[10px] uppercase tracking-[0.3em] text-zen-ink/40 font-medium'}}) }}
                    
                    <div class="relative">
                        {{ form_widget(form.plainPassword, {
                            'attr': {
                                'data-password-visibility-target': 'input',
                                'autocomplete': 'new-password',
                                'class': 'w-full bg-transparent border-b border-zen-ink/10 py-3 pr-10 font-eb-garamond text-lg outline-none focus:border-zen-forest transition-all'
                            }
                        }) }}
                        
                        <button type="button" 
                                data-action="password-visibility#toggle" 
                                class="absolute right-0 bottom-3 text-zen-ink/30 hover:text-zen-forest transition-colors text-sm focus:outline-none"
                                title="Afficher/Masquer le mot de passe">
                            <span data-password-visibility-target="icon">👁️</span>
                        </button>
                    </div>
                </div>

                <hr class="border-zen-ink/5 my-12">

                {# SECTION 2 : MESSAGE #}
                <div class="space-y-2">
                    {{ form_label(form.subject, null, {'label_attr': {'class': 'block text-[10px] uppercase tracking-[0.3em] text-zen-ink/40 font-medium'}}) }}
                    {{ form_widget(form.subject, {'attr': {'class': 'w-full bg-transparent border-b border-zen-ink/10 py-3 font-eb-garamond text-lg outline-none focus:border-zen-forest transition-all'}}) }}
                </div>

                <div class="space-y-2">
                    {{ form_label(form.message, null, {'label_attr': {'class': 'block text-[10px] uppercase tracking-[0.3em] text-zen-ink/40 font-medium'}}) }}
                    {{ form_widget(form.message, {'attr': {'class': 'w-full bg-transparent border border-zen-ink/10 p-6 font-eb-garamond text-lg outline-none focus:border-zen-forest transition-all min-h-[150px] resize-none'}}) }}
                </div>

                <div class="flex justify-end pt-6">
                    <button type="submit" class="group flex flex-col items-end">
                        <span class="text-[11px] font-medium uppercase tracking-[0.4em] text-zen-ink group-hover:text-zen-forest transition-all">
                            Créer mon espace & transmettre →
                        </span>
                        <div class="h-[1px] w-16 bg-zen-ink/20 mt-2 transition-all group-hover:w-full group-hover:bg-zen-forest"></div>
                    </button>
                </div>

            {{ form_end(form) }}
            
        </div>

    </div>
</main>
{% endblock %}
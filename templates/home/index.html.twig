{% extends 'base.html.twig' %}

{% block body %}
<section class="relative min-h-[90vh] flex items-center pt-20 pb-12 overflow-hidden bg-zen-sand">
    
    {# Cercle Zen en arrière-plan #}
    <div class="absolute -right-20 top-0 w-[600px] h-[600px] bg-zen-bronze/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">
            
            {# Colonne Texte #}
            <div class="lg:col-span-7 z-10">
                <span class="font-sans text-[10px] uppercase tracking-[0.4em] text-zen-bronze mb-8 block font-bold">
                    Sandrine Tribhou — Spécialiste Shiatsu
                </span>
                
                {# TITRE CORRIGÉ : leading-[1.1] pour éviter l'écrasement du 'p' sur le 'S' #}
                <h1 class="text-5xl md:text-7xl lg:text-9xl font-serif text-zen-ink italic leading-[1.1] mb-12">
                    L'équilibre <br> 
                    <span class="pl-8 md:pl-20 text-zen-bronze/80">par le</span> <br>
                    <span class="inline-block mt-2 pl-2 md:pl-4">Shiatsu</span>
                </h1>

                <p class="font-sans font-light text-lg md:text-xl text-zen-ink/70 leading-relaxed max-w-xl mb-12 italic">
                    Retrouvez l’harmonie entre le corps et l’esprit. Une approche thérapeutique subtile pour libérer vos tensions et restaurer votre vitalité profonde.
                </p>

                <div class="flex flex-col sm:flex-row items-center gap-6 sm:gap-8">
                    <a href="{{ path('app_service') }}" class="w-full sm:w-auto bg-zen-ink text-zen-sand px-12 py-5 rounded-full font-serif text-xl italic hover:bg-zen-bronze transition-all shadow-xl shadow-zen-ink/10 text-center">
                        Découvrir les soins
                    </a>
                    <a href="#" class="w-full sm:w-auto border border-zen-ink/20 text-zen-ink px-12 py-5 rounded-full font-serif text-xl italic hover:bg-zen-clay/30 transition-all text-center">
                        Ma Philosophie
                    </a>
                </div>
            </div>

            {# ZONE VISUELLE : Affinée pour paraître plus légère #}
            <div class="hidden lg:block lg:col-span-5 relative">
                <div class="aspect-[4/5] relative group">
                    {# Cadre flottant #}
                    <div class="absolute inset-0 border border-zen-bronze/20 rounded-[3rem] translate-x-4 translate-y-4 -z-10"></div>
                    
                    {# Conteneur principal #}
                    <div class="w-full h-full rounded-[3rem] bg-white/40 backdrop-blur-sm border border-white flex flex-col items-center justify-center p-12 text-center shadow-sm">
                        <div class="w-12 h-px bg-zen-bronze/40 mb-8"></div>
                        <p class="font-serif italic text-3xl text-zen-ink/40 leading-relaxed">
                            "Le corps parle, <br> le Shiatsu l'écoute."
                        </p>
                        <div class="w-12 h-px bg-zen-bronze/40 mt-8"></div>
                        
                        <p class="mt-12 font-sans text-[9px] uppercase tracking-[0.3em] text-zen-bronze/60">
                            Empreinte — 2026
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
{% endblock %}
{% extends 'base.html.twig' %}

{% block body %}
<section class="min-h-[80vh] flex flex-col items-center justify-center text-center px-4">
    <span class="text-indigo-600 font-medium tracking-[0.3em] uppercase mb-4 block animate-fade-in">Shiatsu Traditionnel</span>
    <h1 class="text-6xl md:text-8xl font-light text-gray-900 mb-8 tracking-tighter leading-tight">
        Le geste qui <br> <span class="italic font-serif">libère</span> l'énergie.
    </h1>
    <p class="max-w-xl text-gray-500 leading-relaxed text-lg mb-12">
        Une approche authentique et sur-mesure pour retrouver l'équilibre du corps et de l'esprit, au cœur de Toulouse.
    </p>
    <div class="flex gap-6">
        <a href="#catalogue" class="border-b border-gray-900 pb-1 text-sm uppercase tracking-widest font-bold hover:text-gray-500 hover:border-gray-300 transition-all">
            Découvrir les soins
        </a>
    </div>
</section>
{% endblock %}
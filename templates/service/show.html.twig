{% extends 'base.html.twig' %}

{% block title %}{{ service.name }} - L'Empreinte{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 py-24">
    <a href="{{ path('app_service') }}" class="font-sans text-[10px] uppercase tracking-[0.3em] text-zen-bronze hover:text-zen-ink transition-colors mb-20 inline-block">
        ← Retour aux soins
    </a>

    <article>
        {# templates/service/show.html.twig #}
<header class="mb-16 text-center">
    <h1 class="text-4xl sm:text-5xl md:text-7xl font-serif text-zen-ink mb-8 leading-tight break-words mx-auto">
        {{ service.name }}
    </h1>
    
    <div class="flex items-center justify-center gap-8 font-sans text-[10px] uppercase tracking-[0.2em] text-zen-bronze">
        <span class="border-b border-zen-bronze/30 pb-1">{{ service.duration }} minutes</span>
        <span class="text-3xl font-serif italic normal-case text-zen-ink">{{ service.price|number_format(2, ',', ' ') }} €</span>
    </div>
</header>

        <div class="grid grid-cols-1 md:grid-cols-5 gap-20">
            <div class="md:col-span-3">
                <div class="font-serif text-2xl text-zen-ink/90 leading-relaxed space-y-8 italic">
                    {{ service.description|nl2br }}
                </div>
                
                <div class="mt-20">
                    <a href="#" class="inline-block bg-zen-ink text-zen-sand px-16 py-6 font-serif text-2xl italic hover:bg-zen-bronze transition-all duration-500 shadow-2xl">
                        Réserver cette séance
                    </a>
                </div>
            </div>
            
            <aside class="md:col-span-2">
                <div class="sticky top-10 border-l border-zen-clay pl-10 py-4">
                    <p class="font-serif italic text-2xl text-zen-bronze leading-snug">
                        "Écouter le corps pour libérer l'esprit."
                    </p>
                    <p class="mt-6 font-sans text-[10px] uppercase tracking-widest text-zen-ink/40">
                        Sandrine Tribhou — Toulouse
                    </p>
                </div>
            </aside>
        </div>
    </article>
</div>
{% endblock %}
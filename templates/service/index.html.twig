{% extends 'base.html.twig' %}

{% block title %}L'Art du Soin - L'Empreinte{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-6 py-16 md:py-24">
    
    {# Titre centré, plus chaleureux et élégant #}
    <div class="text-center mb-20 md:mb-32">
        <h1 class="text-5xl md:text-8xl font-serif text-zen-ink italic leading-tight mb-4">
            L'Art du Soin
        </h1>
        <div class="w-24 h-px bg-zen-bronze mx-auto opacity-50"></div>
    </div>

    {# Grille corrigée : on force 1 colonne et on ne passe à 2 qu'à partir d'une certaine largeur #}
    <div class="grid grid-cols-1 sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-20 md:gap-x-12 lg:gap-x-20">
        {% for service in services %}
            <article class="flex flex-col border-t border-zen-bronze/20 pt-10 group">
                <h2 class="text-3xl md:text-4xl font-serif text-zen-ink mb-6 group-hover:text-zen-bronze transition-colors duration-500">
                    {{ service.name }}
                </h2>
                
                <div class="font-sans text-[10px] uppercase tracking-[0.3em] text-zen-bronze mb-8">
                    {{ service.duration }} min — {{ service.price|number_format(2, ',', ' ') }} €
                </div>

                <div class="font-serif italic text-xl text-zen-ink/80 leading-relaxed mb-10 flex-grow">
                    {{ service.description|slice(0, 140) ~ '...' }}
                </div>

                <a href="{{ path('app_service_show', {'slug': service.slug}) }}" 
                   class="inline-block font-serif text-2xl italic text-zen-ink border-b border-zen-ink/10 pb-2 w-fit hover:border-zen-bronze hover:text-zen-bronze transition-all">
                    Découvrir l'approche
                </a>
            </article>
        {% endfor %}
    </div>
</div>
{% endblock %}